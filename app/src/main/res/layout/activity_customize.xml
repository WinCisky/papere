<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/back_home_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Back to Home" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/title_settings_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Settings"
                android:textSize="24sp"
                android:textStyle="bold" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/require_wifi_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update only on WiFi"
                android:layout_marginBottom="16dp"
                android:textSize="16sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/require_battery_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update only when charged (>50%)"
                android:layout_marginBottom="16dp"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/title_customize_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Customize"
                android:textSize="24sp"
                android:textStyle="bold" />

            <CheckBox android:id="@+id/checkbox_nature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nature" />
            <CheckBox android:id="@+id/checkbox_landscapes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Landscapes"/>
            <CheckBox android:id="@+id/checkbox_sunsets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sunsets"/>
            <CheckBox android:id="@+id/checkbox_animals"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Animals"/>
            <CheckBox android:id="@+id/checkbox_flora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flora"/>

            <Button
                android:id="@+id/view_logs_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View System Logs"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
