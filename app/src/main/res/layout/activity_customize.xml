<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/back_home_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Back to Home" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/title_settings_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Settings"
                android:textSize="24sp"
                android:textStyle="bold" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/require_wifi_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update only on WiFi"
                android:layout_marginBottom="16dp"
                android:textSize="16sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/require_battery_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update only when charged (>50%)"
                android:layout_marginBottom="16dp"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="Update Frequency"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/update_frequency_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/radio_freq_more"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="More frequent (2h)" />

                <RadioButton
                    android:id="@+id/radio_freq_default"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Default (4h)" />

                <RadioButton
                    android:id="@+id/radio_freq_less"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Less frequent (8h)" />
            </RadioGroup>

            <TextView
                android:id="@+id/title_customize_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Customize"
                android:textSize="24sp"
                android:textStyle="bold" />

            <CheckBox android:id="@+id/checkbox_space"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Space" />
            <CheckBox android:id="@+id/checkbox_objects"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Objects"/>
            <CheckBox android:id="@+id/checkbox_animals"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Animals"/>
            <CheckBox android:id="@+id/checkbox_plants"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plants"/>
            <CheckBox android:id="@+id/checkbox_places"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Places"/>

            <Button
                android:id="@+id/view_logs_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View System Logs"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
